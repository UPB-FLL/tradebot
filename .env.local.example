# Copy to .env.local and fill in. DO NOT commit your real keys.
#
# Get paper trading keys from https://app.alpaca.markets/paper/dashboard/overview
# after creating a free account.

# Required
ALPACA_KEY_ID=PK_YOUR_PAPER_KEY_ID
ALPACA_SECRET_KEY=YOUR_PAPER_SECRET_KEY

# Optional — defaults to the paper endpoint. Only change these if you know
# what you're doing. Real orders hit real money.
# ALPACA_BASE_URL=https://paper-api.alpaca.markets
# ALPACA_BASE_URL=https://api.alpaca.markets
# ALPACA_ALLOW_LIVE=true

# Optional — server-side cap on order quantity. Default 10.
# ALPACA_MAX_QTY=10
